---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Thumbnail from '../assets/exegesis_thumb.svg'
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={Thumbnail} />
    </head>
    <style>
        .unfinished-warning {
            width: 100vw;
            margin-left: 50%;
            transform: translateX(-50%);
            position: relative;
            background: repeating-linear-gradient(
                45deg,
                black 0px,
                black 20px,
                yellow 20px,
                yellow 40px
            );
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0.72em 0;
            margin-top: 1em;
            margin-bottom: 1em;
            overflow: hidden;
        }
        .unfinished-warning-text {
            background: black;
            color: yellow;
            padding: 0 1em;
            font-family: "tiny5", monospace;
            /* font-weight: bold; */
            text-transform: uppercase;
            z-index: 1;
        }
    </style>
    <body>
        <div class="bg-grid"></div>
        <Header />
        <div class="unfinished-warning">
            <span class="unfinished-warning-text">
                <p>404</p>
                <p>how did you get here?</p>
            </span>
        </div>
    </body>
</html>
