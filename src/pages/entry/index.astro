---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, ARCS } from "../../consts";
import StarfieldBackground from "../../components/StarfieldBackground.astro";

// Fetch entries that should be visible: published + in-progress
const activeEntries = (
  await getCollection("entry", ({ data }) => {
    return data.status === "published" || data.status === "in-progress";
  })
).sort((a, b) => a.data.entryNumber - b.data.entryNumber);

// Also fetch draft entry numbers so they appear as placeholders
const allEntries = await getCollection("entry");


// Group entries by arc, sorted by arc order
const entriesByArc = new Map<string, typeof activeEntries>();
for (const entry of activeEntries) {
  const arc = entry.data.arc || "uncategorized";
  if (!entriesByArc.has(arc)) entriesByArc.set(arc, []);
  entriesByArc.get(arc)!.push(entry);
}

// Get arcs in order, only those that have entries
const activeArcs = [...entriesByArc.keys()].sort(
  (a, b) => (ARCS[a]?.order ?? 99) - (ARCS[b]?.order ?? 99),
);

// Fill entries for an arc: show published/in-progress entries,
// plus placeholders for any draft entries that belong to this arc
function buildArcEntries(
  entries: typeof activeEntries,
  arcName: string,
  isLastArc: boolean,
) {
  const result: Array<
    | (typeof activeEntries)[number]
    | { isPlaceholder: true; data: { entryNumber: number; title: string } }
  > = [];
  if (entries.length === 0) return result;

  // Sort active entries by entryNumber
  const sorted = [...entries].sort(
    (a, b) => a.data.entryNumber - b.data.entryNumber,
  );

  // Find draft entry numbers that belong to this arc
  const arcDrafts = allEntries
    .filter(
      (e) =>
        e.data.status === "draft" &&
        (e.data.arc === arcName ||
          (!e.data.arc && arcName === "uncategorized")),
    )
    .map((e) => e.data.entryNumber)
    .sort((a, b) => a - b);

  // Merge active entries and draft placeholders in order
  let activeIdx = 0;
  let draftIdx = 0;
  while (activeIdx < sorted.length || draftIdx < arcDrafts.length) {
    const activeNum =
      activeIdx < sorted.length ? sorted[activeIdx].data.entryNumber : Infinity;
    const draftNum =
      draftIdx < arcDrafts.length ? arcDrafts[draftIdx] : Infinity;

    if (activeNum < draftNum) {
      result.push(sorted[activeIdx++]);
    } else {
      result.push({
        isPlaceholder: true,
        data: { entryNumber: draftNum, title: "in-progress" },
      });
      draftIdx++;
    }
  }

  // One trailing placeholder on the last arc only
  if (isLastArc) {
    const maxNum =
      result.length > 0 ? result[result.length - 1].data.entryNumber : 0;
    result.push({
      isPlaceholder: true,
      data: { entryNumber: maxNum + 1, title: "in-progress" },
    });
  }
  return result;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
        margin-bottom: 10vh;
      }
      .arc-section {
        margin-bottom: 2rem;
      }
      .arc-section:first-child {
        margin-top: 2rem;
      }
      .arc-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .arc-header h3 {
        margin: 0;
        font-family: var(--font-tiny5);
        font-size: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-align: center;
        text-wrap: balance;
      }
      .arc-header h3 a {
        color: inherit;
        text-decoration: none;
      }
      .arc-header-line {
        flex: 1;
        min-width: 2rem;
        height: 2px;
        background: currentColor;
        opacity: 0.5;
      }
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li {
        width: calc(50% - 1rem);
      }
      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }
      .entry-card {
        display: block;
        position: relative;
      }
      .entry-card img {
        display: block;
        width: 100%;
      }
      .entry-card .unfinished-banner {
        position: absolute;
        top: 66.66%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        background: var(--warning-gradient);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0.72em 0;
        overflow: hidden;
        z-index: 1;
      }
      .entry-card .unfinished-banner span {
        background: black;
        color: yellow;
        padding: 0.1em 1em;
        font-family: var(--font-tiny5);
        text-transform: uppercase;
      }
      ul li img {
        margin-bottom: 0.5rem;
      }
      ul li a {
        display: block;
      }
      .entry-number {
        color: rgb(var(--gray));
      }
      .entry-title {
        color: white;
        font-family: var(--font-tiny5);
        text-align: center;
        margin: 0;
        line-height: 1;
      }
      .placeholder-wrapper {
        display: block;
      }
      .placeholder-image {
        background-color: #111;
        border: 1px dashed rgb(var(--gray));
        box-sizing: border-box;
        aspect-ratio: 4 / 3;
        width: 100%;
        margin-bottom: 0.5rem;
      }
      .placeholder-wrapper .entry-title {
        opacity: 0.6;
      }
      @media (max-width: 840px) {
        ul {
          gap: 4rem;
        }
        ul li {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <StarfieldBackground />

    <Header />

    <main class="crosshair-corners">
      {
        activeArcs.map((arc, idx) => {
          const arcInfo = ARCS[arc] ?? { name: arc, color: "#808080" };
          const isLastArc = idx === activeArcs.length - 1;
          const arcEntries = buildArcEntries(
            entriesByArc.get(arc)!,
            arc,
            isLastArc,
          );
          return (
            <div class="arc-section" id={arc}>
              <div class="arc-header" style={`color: ${arcInfo.color};`}>
                <div class="arc-header-line" />
                <h3>
                  <a href={`#${arc}`}>{arcInfo.name}</a>
                </h3>
                <div class="arc-header-line" />
              </div>
              <ul>
                {arcEntries.map((entry) => (
                  <li>
                    {"isPlaceholder" in entry ? (
                      <div class="placeholder-wrapper">
                        <div class="placeholder-image" />
                        <h4 class="entry-title">
                          <span class="entry-number">
                            {entry.data.entryNumber}.
                          </span>{" "}
                          {entry.data.title}
                        </h4>
                      </div>
                    ) : (
                      <a
                        class="entry-card crosshair-corners crosshair-blink crosshair-small"
                        href={`/entry/${entry.id}/`}
                      >
                        {entry.data.heroImage && (
                          <img src={entry.data.heroImage.src} alt="" />
                        )}
                        {entry.data.status === "in-progress" && (
                          <div class="unfinished-banner">
                            <span>Unfinished</span>
                          </div>
                        )}
                        <h4 class="entry-title">
                          <span class="entry-number">
                            {entry.data.entryNumber}.
                          </span>{" "}
                          {entry.data.title}
                        </h4>
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </main>
  </body>
</html>
