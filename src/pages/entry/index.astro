---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, ARCS } from '../../consts';

// Fetch entries that should be visible: published + in-progress
const activeEntries = (await getCollection('entry', ({ data }) => {
  return data.status === 'published' || data.status === 'in-progress';
})).sort(
  (a, b) => a.data.entryNumber - b.data.entryNumber,
);

// Group entries by arc, sorted by arc order
const entriesByArc = new Map<string, typeof activeEntries>();
for (const entry of activeEntries) {
  const arc = entry.data.arc || 'uncategorized';
  if (!entriesByArc.has(arc)) entriesByArc.set(arc, []);
  entriesByArc.get(arc)!.push(entry);
}

// Get arcs in order, only those that have entries
const activeArcs = [...entriesByArc.keys()]
  .sort((a, b) => (ARCS[a]?.order ?? 99) - (ARCS[b]?.order ?? 99));

// Fill placeholders: for each arc, fill gaps between min/max entry numbers
function buildArcEntries(entries: typeof activeEntries) {
  const result: Array<typeof activeEntries[number] | { isPlaceholder: true; data: { entryNumber: number; title: string } }> = [];
  if (entries.length === 0) return result;
  const min = entries[0].data.entryNumber;
  const max = entries[entries.length - 1].data.entryNumber;
  const entryMap = new Map(entries.map(e => [e.data.entryNumber, e]));
  for (let i = min; i <= max; i++) {
    if (entryMap.has(i)) {
      result.push(entryMap.get(i)!);
    } else {
      result.push({
        isPlaceholder: true,
        data: { entryNumber: i, title: 'in-progress' },
      });
    }
  }
  return result;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
        margin-bottom: 10vh;
      }
      .arc-section {
        margin-bottom: 2rem;
      }
      .arc-section:first-child {
        margin-top: 2rem;
      }
      .arc-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .arc-header h3 {
        margin: 0;
        font-family: var(--font-tiny5);
        font-size: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
      }
      .arc-header h3 a {
        color: inherit;
        text-decoration: none;
      }
      .arc-header-line {
        flex: 1;
        height: 2px;
        background: currentColor;
        opacity: 0.5;
      }
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li {
        width: calc(50% - 1rem);
      }
      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }
      .entry-card {
        display: block;
        position: relative;
      }
      .entry-card img {
        display: block;
        width: 100%;
      }
      .entry-card .unfinished-banner {
        position: absolute;
        top: 66.66%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        background: var(--warning-gradient);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0.72em 0;
        overflow: hidden;
        z-index: 1;
      }
      .entry-card .unfinished-banner span {
        background: black;
        color: yellow;
        padding: 0.1em 1em;
        font-family: var(--font-tiny5);
        text-transform: uppercase;
      }
      ul li img {
        margin-bottom: 0.5rem;
      }
      ul li a {
        display: block;
      }
      .entry-number {
        color: rgb(var(--gray));
      }
      .entry-title {
        color: white;
        font-family: var(--font-tiny5);
        text-align: center;
        margin: 0;
        line-height: 1;
      }
      .placeholder-wrapper {
        display: block;
      }
      .placeholder-image {
        background-color: #111;
        border: 1px dashed rgb(var(--gray));
        aspect-ratio: 4 / 3;
        width: 100%;
        margin-bottom: 0.5rem;
      }
      .placeholder-wrapper .entry-title {
        opacity: 0.6;
      }
      @media (max-width: 840px) {
        ul {
          gap: 0.5em;
        }
        ul li {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-grid"></div>

    <Header />

    <main>
      {activeArcs.map((arc) => {
        const arcInfo = ARCS[arc] ?? { name: arc, color: '#808080' };
        const arcEntries = buildArcEntries(entriesByArc.get(arc)!);
        return (
          <div class="arc-section" id={arc}>
            <div class="arc-header" style={`color: ${arcInfo.color};`}>
              <div class="arc-header-line"></div>
              <h3><a href={`#${arc}`}>{arcInfo.name}</a></h3>
              <div class="arc-header-line"></div>
            </div>
            <ul>
              {arcEntries.map((entry) => (
                <li>
                  {'isPlaceholder' in entry ? (
                    <div class="placeholder-wrapper">
                      <div class="placeholder-image"></div>
                      <h4 class="entry-title">
                        <span class="entry-number">{entry.data.entryNumber}.</span> {entry.data.title}
                      </h4>
                    </div>
                  ) : (
                    <a
                      class="entry-card"
                      href={`/entry/${entry.id}/`}
                    >
                      {entry.data.heroImage && <img src={entry.data.heroImage.src} alt="" />}
                      {entry.data.status === 'in-progress' && (
                        <div class="unfinished-banner">
                          <span>Unfinished</span>
                        </div>
                      )}
                      <h4 class="entry-title">
                        <span class="entry-number">{entry.data.entryNumber}.</span> {entry.data.title}
                      </h4>
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </main>
  </body>
</html>
