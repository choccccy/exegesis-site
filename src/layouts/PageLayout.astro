---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = {
    title: string;
    description: string;
    heroImage?: string;
}

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage}/>
    <style>
      main {
        max-width: 100%;
        /* margin-top: 2vh; */
      }
      /* .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-light));
      } */
      .prose p {
        margin-bottom: 1em;
      }
      .title {
        margin-bottom: 0;
        padding: 1em 0 0.25em 0;
        text-align: center;
        line-height: 1;
        font-family: "tiny5";
        background: black;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
      }
      .title h1 {
        margin: 0;
      }
    </style>
  </head>

  <body>
    <div class="bg-grid"></div>

    <Header />

    <!-- <div class="title">
        <h1>{title}</h1>
    </div> -->

    <main>
        <div class="prose">
          <slot />
        </div>
    </main>

    <!-- <Footer /> -->

  </body>
</html>
