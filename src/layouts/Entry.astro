---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EntryNavigation from '../components/EntryNavigation.astro';
import Header from '../components/Header.astro';
import WarningBanner from '../components/WarningBanner.astro';
import NavButton from '../components/NavButton.astro';
import StarfieldBackground from '../components/StarfieldBackground.astro';

type Props = CollectionEntry<'entry'>['data'];

const { status, arc, title, showTitle, description, previousEntry, nextEntry, heroImage, NSFW } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} embedCard="summary_large_image"/>
    <style>
      main {
        max-width: 100%;
      }
      .prose {
        width: 100%;
        margin: 0;
        padding: 0;
      }
      .title {
        margin-bottom: 0;
        padding: 1em;
        text-align: center;
        line-height: 1;
        font-family: var(--font-tiny5);
        background: black;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
      }
      .title h1 {
        margin: 0;
      }
      #nsfw-actions {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
        margin: 1.5em 0;
        padding: 0;
      }
    </style>
  </head>

  <body>
    <StarfieldBackground />

    <Header />
    
    {showTitle !== false && (
    <div class="title">
      <h1>{title}</h1>
    </div>
    )}

    {(status === 'in-progress' || status === 'draft') && (<WarningBanner lines={[ 'this entry is unfinished! content is subject to change.' ]} />)}

    <main>
      {!NSFW ? (
        <div class="prose">
          <slot />
        </div>
      ) : (
        <>
          <div id="nsfw-warning">
            <WarningBanner
              variant="nsfw"
              lines={[
                'This section contains mature, NSFW themes for adults.',
                'Would you like to continue to read this entry, or skip this section?'
              ]}
            />
            <div id="nsfw-actions">
              <NavButton
                id="nsfw-confirm-btn"
                type="warning"
                ariaLabel="Confirm viewing NSFW content"
              >
                Continue
              </NavButton>
              <NavButton
                id="nsfw-skip-btn"
                type="next"
                ariaLabel="Skip NSFW content and return"
              >
                Skip
              </NavButton>
            </div>
          </div>

          <div id="entry-content" class="prose" style="display:none;">
            <slot />
          </div>
        </>
      )}
    </main>

    {(status === 'in-progress' || status === 'draft') && (
      <WarningBanner lines={['this entry is unfinished! content is subject to change.']} />
    )}

    <div id="entry-nav-wrapper" style={NSFW ? 'display:none;' : ''}>
      <EntryNavigation
        currentEntry={title}
        currentStatus={status}
        arc={arc}
        previousEntry={previousEntry}
        nextEntry={nextEntry}
      />
    </div>
  </body>
</html>

<script is:inline>
  try {
    const warning = document.querySelector('#nsfw-warning')
    const content = document.querySelector('#entry-content')
    const navWrapper = document.querySelector('#entry-nav-wrapper')
    const confirmed = localStorage.getItem('nsfwConfirmed')

    if (confirmed === 'true') {
      content.style.display = ''
      warning.style.display = 'none'
      navWrapper.style.display = ''
    }

    document.querySelector('#nsfw-confirm-btn')?.addEventListener('click', () => {
      localStorage.setItem('nsfwConfirmed', 'true')
      content.style.display = ''
      warning.style.display = 'none'
      navWrapper.style.display = ''
    })

    document.querySelector('#nsfw-skip-btn')?.addEventListener('click', () => {
      warning.style.display = 'none'
      navWrapper.style.display = ''
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  } catch (e) {
    // localStorage may be unavailable in privacy-mode browsers
  }
</script>
