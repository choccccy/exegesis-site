---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import EntryNavigation from '../components/EntryNavigation.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import WarningBanner from '../components/WarningBanner.astro';

type Props = CollectionEntry<'entry'>['data'];

const { published, title, showTitle, description, previousEntry, nextEntry, heroImage } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} image={heroImage}/>
        <style>
            main {
                /* width: calc(100% - 2em); */
                max-width: 100%;
                /* margin: 0; */
            }
            .hero-image {
                width: 100%;
            }
            .hero-image img {
                display: block;
                /* margin: 0 0; */
                /* border-radius: 12px; */
                /* box-shadow: var(--box-shadow); */
            }
            .prose {
                width: 100%;
                margin: 0;
                padding: 0;
                /* color: rgb(var(--gray-dark)); */
            }
            .title {
                margin-bottom: 0;
                padding: 1em 0 0.25em 0;
                text-align: center;
                line-height: 1;
                font-family: "tiny5";
                background: black;
                width: fit-content;
                margin-left: auto;
                margin-right: auto;
            }
            .title h1 {
                margin: 0;
            }
            .date {
                margin-bottom: 0.5em;
                color: rgb(var(--gray));
            }
            .last-updated-on {
                font-style: italic;
            }
        </style>
    </head>

    <body>
        <div class="bg-grid"></div>
        <Header />
        <div class="title">
            {showTitle !== false && (
            <h1>{title}</h1>
            )}
            {/* <hr /> */}
        </div>
        {published == false && (<WarningBanner lines={[ 'this entry is unfinished! content is subject to change.' ]} />)}
        <main>
            <div class="prose">
                <slot />
            </div>
        </main>
        {published == false && (<WarningBanner lines={[ 'this entry is unfinished! content is subject to change.' ]} />)}
        <EntryNavigation 
            currentEntry={title}
            previousEntry={previousEntry}
            nextEntry={nextEntry}
        />
    </body>
</html>
