---
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{
  as: Tag;
  blink?: boolean;
  active?: boolean;
  size?: string;
  thickness?: string;
  small?: boolean;
}>;

const {
  as: Tag = "div",
  blink = false,
  active = false,
  size,
  thickness,
  small = false,
  class: className,
  style,
  ...props
} = Astro.props;

// Prepare CSS variables for custom sizing
const customVars = {
  ...(size && { "--crosshair-size": size }),
  ...(thickness && { "--crosshair-thick": thickness }),
};
---

<Tag
  class:list={[
    "crosshair-corners",
    { "crosshair-blink": blink, "crosshair-on": active, "crosshair-small": small },
    className
  ]}
  style={{ ...customVars, ...style }}
  {...props}
>
  <slot />
</Tag>
