<style>
  header {
    margin: 0;
    padding: 5vh 5vw 0 5vw;
    color: white;
    background: #00000000;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  .logo-img {
    outline: 0px;
    height: 80%;
    width: auto;
    display: block;
    object-fit: contain;
  }
  .internal-links {
    height: 100%;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    gap: 1em;
  }
  .internal-links a {
    display: flex;
    align-items: center;
    height: 100%;
    border-bottom: 4px solid transparent;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .internal-links a.active {
    border-bottom-color: white;
  }
  .diamond-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);  /* diamond with four points at mid-top/right/bottom/left */
    background: currentColor;
  }
  .diamond-icon svg {
    /* Make the icon fill the parent */
    width: 50%;
    height: 50%;
    object-fit: contain;
    fill: backgroundColor;
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    height: 10vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: white;
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 840px) {
    nav {
      flex-direction: column;
      height: auto;
      gap: 1rem;
    }
    .internal-links {
      position: static;
      transform: none;
    }
    .logo-img {
      width: 65vw;
      height: auto;
    }
  }
</style>
