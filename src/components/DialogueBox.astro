---
const palette = {
  Antikythera: '#C0C0C0',
  // Expedition team Amur
  Ncho: '#C499FF',
  Obi: ['#99f6ff', '#202020'],
  // SAR team
  V3N: '#FFA500',
  TL: '#98FBCB',
  Medic: '#9F9FFF',
  SO: ['#FF8080', '#202020'],
  CO: ['#FFFF00', '#202020'],
  // Misc.
  Lemaitre: '#6E8EFF',
  Muhammad: '#00C000',
  Delta_Titan: '#C00000',
  // Fallback
  fallback: '#FF00FF'
};

const backgroundAlpha = 0.16;
const borderDarken = 0.5;

const { char: rawChar = 'default', bgOverride } = Astro.props;
const char = rawChar.toLowerCase();

function withAlpha(hex: string, alpha: number) {
  const match = hex.match(/^#(..)(..)(..)$/);
  const [, r, g, b] = match ? match.map((x: string) => parseInt(x, 16)) : [0, 0, 0, 0];
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}
function darken(hex: string, factor = borderDarken) {
  const match = hex.match(/^#(..)(..)(..)$/);
  const [, r, g, b] = match ? match.map((x: string) => parseInt(x, 16)) : [0, 0, 0, 0];
  return `rgb(${Math.round(r*factor)}, ${Math.round(g*factor)}, ${Math.round(b*factor)})`;
}

const paletteKey = Object.keys(palette).find(k => k.toLowerCase() === char) as keyof typeof palette | undefined;
const characterName = paletteKey || rawChar;

const entry = (paletteKey ? palette[paletteKey] : undefined) ?? palette.fallback;

const baseColor = Array.isArray(entry) ? entry[0] : entry;
const background =
  bgOverride ? bgOverride :
  (Array.isArray(entry) && entry[1]) ? entry[1] :
  withAlpha(baseColor, backgroundAlpha);

const border = darken(baseColor, borderDarken);
---

<span
  class={`db ${char}`}
  style={`color:${baseColor}; background:${background}; border-left:4px solid ${border};`}
  title={`${characterName} dialogue`}
>
  <slot />
</span>

<style is:global>
  .db {
    display: inline;
    vertical-align: baseline;
    padding: 0.3em 0.4em;
    margin-right: 0.4em;
    word-break: break-word;
    white-space: normal;
    line-height: 1.5;
  }

  .db:not(p .db) {
    display: block;
    margin-top: var(--paragraph-margin);
    margin-bottom: var(--paragraph-margin);
    width: fit-content;
    max-width: var(--prose-width);
    margin-left: var(--prose-indent);
    margin-right: auto;
  }

  p .db {
    display: inline;
    margin-bottom: 0;
  }

  .db code + code {
    margin-left: 1.5em;
  }
</style>