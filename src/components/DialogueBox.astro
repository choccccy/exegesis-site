---
const { char = 'default' } = Astro.props;

const palette = {
  antikythera: '#C0C0C0',
  ncho: '#C499FF',
  obi: '#C499FF',
  lemaitre: '#6E8EFF',
  v3n: '#8DDCDC',
  default: '#FF00FF'
};

const backgroundAlpha = 0.16;
const borderDarken = 0.5;

const baseColor = palette[char] ?? palette.default;

function withAlpha(hex, alpha) {
  const [, r, g, b] = hex.match(/^#(..)(..)(..)$/).map(x => parseInt(x, 16));
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}
function darken(hex, factor = borderDarken) {
  const [, r, g, b] = hex.match(/^#(..)(..)(..)$/).map(x => parseInt(x, 16));
  return `rgb(${Math.round(r*factor)}, ${Math.round(g*factor)}, ${Math.round(b*factor)})`;
}

const background = withAlpha(baseColor, backgroundAlpha);
const border = darken(baseColor, borderDarken);
---

<span
  class={`db ${char}`}
  style={`color:${baseColor}; background:${background}; border-left:4px solid ${border};`}
>
  <slot />
</span>

<style is:global>
  .db {
    display: inline;
    vertical-align: baseline;
    padding: 0.3em 0.4em;
    margin-right: 0.4em;
    border-left: 4px solid;
    word-break: break-word;
    white-space: normal;
    line-height: inherit;
  }

  .db:not(p .db) {  /* Target standalone dialogue boxes that are NOT inside paragraphs */
    display: block !important;
    margin-bottom: var(--paragraph-margin);
    width: fit-content;
  }

  p .db {  /* Ensure inline dialogue boxes stay inline */
    display: inline !important;
    margin-bottom: 0;
  }

  .db code + code {  /* Code gapping */
    margin-left: 1.5em;
  }
</style>