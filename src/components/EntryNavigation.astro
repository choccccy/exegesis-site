---
import { getCollection } from 'astro:content'
import { ARCS } from '../consts';
import NavButton from '../components/NavButton.astro'
import CrosshairContainer from '../components/CrosshairContainer.astro'

interface Props {
  currentEntry: string
  currentStatus: string
  arc: string
  previousEntry?: string | null
  nextEntry?: string | null
}

const { currentEntry, currentStatus, arc, previousEntry, nextEntry } = Astro.props

const arcInfo = ARCS[arc] ?? { name: arc, color: '#808080' };
const arcHash = arc || '';

const allEntries = await getCollection('entry')

function getEntryStatus(entryTitle: string): string | undefined {
  return allEntries.find(e => e.data.title === entryTitle)?.data.status
}

function titleToSlug(title: string): string {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
}

const previousStatus = previousEntry ? getEntryStatus(previousEntry) : undefined
const nextStatus = nextEntry ? getEntryStatus(nextEntry) : undefined

// Previous link is active if the previous entry is published or in-progress (never draft)
const isPreviousActive = previousStatus === 'published' || previousStatus === 'in-progress'

// Next link is active if:
//   - target is 'published' (always OK), OR
//   - current is 'in-progress' or 'draft' AND target is 'in-progress' (flow continues within unpublished content)
const isNextActive =
  nextStatus === 'published' ||
  ((currentStatus === 'in-progress' || currentStatus === 'draft') && nextStatus === 'in-progress')
---

<nav class="entry-navigation" role="navigation" aria-label="Entry navigation">
  <div class="nav-group">
    <div class="nav-item-wrapper prev">
      {previousEntry ? (
        isPreviousActive ? (
          <CrosshairContainer blink small class="nav-button-wrapper">
            <NavButton
              type="previous"
              href={`/entry/${titleToSlug(previousEntry)}/`}
              ariaLabel={`Previous entry: ${previousEntry}`}
            >
              {previousEntry}
            </NavButton>
          </CrosshairContainer>
        ) : (
          <NavButton
            type={['previous', 'disabled']}
            ariaLabel={`Previous entry not yet published: ${previousEntry}`}
            title="This entry is not yet published"
          >
            {'{...}'}
          </NavButton>
        )
      ) : (
        <NavButton type="placeholder" aria-hidden="true" />
      )}
    </div>

    <CrosshairContainer active small class="nav-button-wrapper current">
      <NavButton
        type="current"
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        ariaLabel={`Back to top of ${currentEntry}`}
      >
        {currentEntry}
      </NavButton>
    </CrosshairContainer>

    <div class="nav-item-wrapper next">
      {nextEntry ? (
        isNextActive ? (
          <CrosshairContainer blink small class="nav-button-wrapper">
            <NavButton
              type="next"
              href={`/entry/${titleToSlug(nextEntry)}/`}
              ariaLabel={`Next entry: ${nextEntry}`}
            >
              {nextEntry}
            </NavButton>
          </CrosshairContainer>
        ) : (
          <NavButton
            type={['next', 'disabled']}
            ariaLabel="No next entry available"
          >
            {'{...}'}
          </NavButton>
        )
      ) : (
        <NavButton
          type={['next', 'disabled']}
          ariaLabel="No next entry available"
        >
          {'{...}'}
        </NavButton>
      )}
    </div>

    <div class="arc-label-wrapper">
      <a class="arc-label" href={`/entry/#${arcHash}`} style={`color: ${arcInfo.color};`}>{arcInfo.name}</a>
    </div>
  </div>
</nav>

<style>
  .entry-navigation {
    margin: 1.5em 0 0 0;
  }

  .arc-label-wrapper {
    text-align: center;
    grid-column: 2;
    margin: 1rem 0 0 0;
  }

  .arc-label {
    display: inline-block;
    padding: 0.3em 0.75em;
    font-family: var(--font-tiny5);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: black;
    text-decoration: none;
    border: none;
  }
  .arc-label:hover,
  .arc-label:active,
  .arc-label:visited {
    text-decoration: none;
    border: none;
  }

  .nav-group {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    column-gap: 3rem;
  }

  /* Ensure the wrappers respect the grid layout of the buttons they contain */
  .nav-item-wrapper {
    display: flex;
    height: 100%;
  }
  .nav-item-wrapper.prev { grid-column: 1; justify-self: end; }
  .nav-item-wrapper.next { grid-column: 3; justify-self: start; }
  .nav-button-wrapper.current { grid-column: 2; justify-self: center; }

  /* Ensure buttons inside wrappers take up full space */
  .nav-button-wrapper :global(.nav-button) {
    width: 100%;
  }

  @media (max-width: 840px) {
    .nav-group {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      margin: 1em;
    }
    .nav-item-wrapper.prev { order: 1; }
    .nav-button-wrapper.current { order: 2; }
    .arc-label-wrapper { 
      order: 3; 
      margin: -1.25rem 0 -1.25rem 0; /* Pull closer to current button as in the screenshot request */
    }
    .nav-item-wrapper.next { order: 4; }
  }
</style>
