---
import { getCollection } from 'astro:content'
import NavButton from '../components/NavButton.astro'

interface Props {
  currentEntry: string
  previousEntry?: string | null
  nextEntry?: string | null
}

const { currentEntry, previousEntry, nextEntry } = Astro.props

const publishedEntries = await getCollection('entry', ({ data }) => data.published === true)

function isEntryPublished(entryTitle: string): boolean {
  return publishedEntries.some(entry => entry.data.title === entryTitle)
}

function titleToSlug(title: string): string {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
}

const isPreviousPublished = previousEntry ? isEntryPublished(previousEntry) : false
const isNextPublished = nextEntry ? isEntryPublished(nextEntry) : false
---

<nav class="entry-navigation" role="navigation" aria-label="Entry navigation">
  <div class="nav-group">
    {previousEntry ? (
      isPreviousPublished ? (
        <NavButton
          type="previous"
          href={`/entry/${titleToSlug(previousEntry)}/`}
          ariaLabel={`Previous entry: ${previousEntry}`}
        >
          {previousEntry}
        </NavButton>
      ) : (
        <NavButton
          type={['previous', 'disabled']}
          ariaLabel={`Previous entry not yet published: ${previousEntry}`}
          title="This entry is not yet published"
        >
          {'{...}'}
        </NavButton>
      )
    ) : (
      <NavButton type="placeholder" aria-hidden="true" />
    )}

    <NavButton
      type="current"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
      ariaLabel={`Back to top of ${currentEntry}`}
    >
      {currentEntry}
    </NavButton>

    {nextEntry ? (
      isNextPublished ? (
        <NavButton
          type="next"
          href={`/entry/${titleToSlug(nextEntry)}/`}
          ariaLabel={`Next entry: ${nextEntry}`}
        >
          {nextEntry}
        </NavButton>
      ) : (
        <NavButton
          type={['next', 'disabled']}
          ariaLabel="No next entry available"
        >
          {'{...}'}
        </NavButton>
      )
    ) : (
      <NavButton
        type={['next', 'disabled']}
        ariaLabel="No next entry available"
      >
        {'{...}'}
      </NavButton>
    )}
  </div>
</nav>

<style>
  .entry-navigation {
    margin: 1.5em 0 10vh 0;
  }

  .nav-group {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    column-gap: 1.25rem;
  }

  @media (max-width: 840px) {
    .nav-group {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin: 1em;
    }
  }
</style>
