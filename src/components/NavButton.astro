---
type ButtonType = 'default' | 'current' | 'previous' | 'next' | 'disabled' | 'placeholder' | 'warning';

export interface Props {
  type?: ButtonType | ButtonType[];
  href?: string
  id?: string
  ariaLabel?: string
  [key: string]: unknown
}
const { type = 'default', href, id, ariaLabel, ...rest } = Astro.props;

const typeClasses = (Array.isArray(type) ? type : [type]).map(t => `nav-button--${t}`).join(' ');
---
{href ? (
  <a
    href={href}
    class:list={['nav-button', typeClasses]}
    aria-label={ariaLabel}
    id={id}
    {...rest}
  >
    <span class="nav-text"><slot /></span>
  </a>
) : (
  <button
    class:list={['nav-button', typeClasses]}
    aria-label={ariaLabel}
    id={id}
    type="button"
    {...rest}
  >
    <span class="nav-text"><slot /></span>
  </button>
)}

<style>
  .nav-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: white;
    color: black;
    text-decoration: none;
    font-family: var(--font-tiny5);
    font-size: 2rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    line-height: 1.2;
    border: none;
    position: relative;
    box-sizing: border-box;
    max-width: none;
  }

  .nav-button--default {
    background: white;
    color: black;
    border: 2px solid black;
    border-radius: 0;
  }

  .nav-button--previous {
    background: white;
    color: black;
    clip-path: polygon(28px 0%, 100% 0%, 100% 100%, 28px 100%, 0% 50%);
    padding-left: 36px;
    justify-self: end;
  }

  .nav-button--next {
    background: white;
    color: black;
    clip-path: polygon(0% 0%, calc(100% - 28px) 0%, 100% 50%, calc(100% - 28px) 100%, 0% 100%);
    padding-right: 36px;
    justify-self: start;
  }

  .nav-button--current {
    background: black;
    color: white;
    z-index: 1;
    justify-self: center;
  }

  .nav-button--disabled {
    background: #808080;
    color: black;
    cursor: not-allowed;
  }

  .nav-button--placeholder {
    visibility: hidden;
    pointer-events: none;
    clip-path: polygon(28px 0%, 100% 0%, 100% 100%, 28px 100%, 0% 50%);
    padding-left: 36px;
    justify-self: end;
  }

  .nav-text {
    white-space: nowrap;
    text-align: center;
    display: inline-block;
  }

  .nav-button--warning {
    background: var(--nsfw-gradient);
    color: black;
    border: 2px solid black;
    border-radius: 0;
    padding: 0.75rem 1.5rem;
    box-sizing: border-box;
  }

  .nav-button--warning .nav-text {
    background: black;
    color: #ff6600;
    padding: 0 0.3em;
    display: inline-block;
    line-height: 1.2;
    border-radius: 0;
  }

  @media (max-width: 840px) {
    .nav-button--previous,
    .nav-button--next,
    .nav-button--current,
    .nav-button--default {
      width: 80%;
      padding: 0.75rem 1.25rem;
    }
    .nav-button--placeholder {
      display: none;
    }
  }
</style>
