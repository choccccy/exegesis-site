---
/**
 * StarfieldBackground component
 * Renders a sparse, realistic starfield with hardware-accelerated CSS parallax
 * Uses pre-rendered seamless textures to achieve 60fps performance without motion blur
 */

interface Props {
  starCount?: number;
}

const { starCount = 800 } = Astro.props;
---

<starfield-background data-star-count={starCount}>
  <div id="starfield-wrapper">
    <div class="starfield-layer" id="starfield-bg"></div>
    <div class="starfield-layer" id="starfield-md"></div>
    <div class="starfield-layer" id="starfield-fg"></div>
  </div>
</starfield-background>

<script src="./starfieldBackground.ts"></script>

<style>
  #starfield-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
    background-color: #000000;
  }

  .starfield-layer {
    position: absolute;
    top: -50px;
    left: -50px;
    right: -50px;
    bottom: -50px;
    background-repeat: repeat;
    /* Hardware acceleration hint */
    will-change: background-position;
    /* Screen blend mode ensures the black background becomes transparent, 
       perfectly preserving the pre-blended RGB canvas colors */
    mix-blend-mode: screen;
  }

  /* Different speeds for parallax. 
     We subtract --scroll-y so the background moves UP as you scroll DOWN,
     mimicking things moving past you natively. */
  #starfield-bg {
    /* 10% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.1);
  }

  #starfield-md {
    /* 30% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.3);
  }

  #starfield-fg {
    /* 60% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.6);
  }
</style>
