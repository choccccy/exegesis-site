---
/**
 * StarfieldBackground component
 * Renders a sparse, realistic starfield with subtle mouse parallax
 * Hard sci-fi aesthetic: static stars, minimal movement
 */

interface Props {
  starCount?: number;
}

const { starCount = 400 } = Astro.props;
---

<div class="starfield-wrapper">
  <canvas id="starfield-canvas"></canvas>
</div>

<script define:vars={{ starCount }} client:only>
  class Star {
    constructor(width, height) {
      this.width = width;
      this.height = height;
      this.init();
    }

    init() {
      // Position
      this.x = Math.random() * this.width;
      this.y = Math.random() * this.height;

      // Depth layer (1-3, 1=far/dim, 3=near/bright)
      this.depth = Math.random() < 0.7 ? 1 : Math.random() < 0.85 ? 2 : 3;

      // Size based on depth
      const sizes = [1, 1.5, 2];
      this.baseSize = sizes[this.depth - 1] * (0.8 + Math.random() * 0.4);

      // Opacity based on depth (bright stars = pure white, no dimming)
      const opacities = [0.3, 0.6, 1.0];
      this.baseOpacity = opacities[this.depth - 1];

      // Star colors (mostly white, slight variations)
      const colors = [
        "#ffffff",
        "#ffffff",
        "#ffffff",
        "#ffffff", // majority white
        "#f0f0f0",
        "#e8e8ff",
        "#ffe8e0",
        "#fffff0", // subtle tints
      ];
      this.color = colors[Math.floor(Math.random() * colors.length)];
    }

    update(mouseX, mouseY, canvasWidth, canvasHeight) {
      // Parallax offset based on depth
      const parallaxStrength = this.depth * 8;
      const offsetX = (mouseX - 0.5) * parallaxStrength;
      const offsetY = (mouseY - 0.5) * parallaxStrength;

      this.drawX = this.x + offsetX;
      this.drawY = this.y + offsetY;

      // Wrap around edges (seamless)
      if (this.drawX < -10) this.drawX += canvasWidth + 20;
      if (this.drawX > canvasWidth + 10) this.drawX -= canvasWidth + 20;
      if (this.drawY < -10) this.drawY += canvasHeight + 20;
      if (this.drawY > canvasHeight + 10) this.drawY -= canvasHeight + 20;
    }

    draw(ctx) {
      // All stars are single pixel, brightness varies
      ctx.globalAlpha = this.baseOpacity;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.drawX, this.drawY, 1, 0, Math.PI * 2);
      ctx.fill();

      // Diffraction spikes on all stars (scaled by brightness, prominent)
      const spikeAlpha = this.baseOpacity * 0.48;
      ctx.lineWidth = 1;
      const spikeLength = this.baseSize * 16;

      // Parse color for gradient - handle hex colors
      const hex = this.color;
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);

      // Draw 4 diagonal arms with wide, gradual tapering
      const arms = [
        {
          x1: this.drawX - spikeLength,
          y1: this.drawY - spikeLength,
          x2: this.drawX + spikeLength,
          y2: this.drawY + spikeLength,
        },
        {
          x1: this.drawX + spikeLength,
          y1: this.drawY - spikeLength,
          x2: this.drawX - spikeLength,
          y2: this.drawY + spikeLength,
        },
      ];

      arms.forEach((arm) => {
        const grad = ctx.createLinearGradient(arm.x1, arm.y1, arm.x2, arm.y2);
        grad.addColorStop(0, `rgba(${r},${g},${b},0)`);
        grad.addColorStop(0.35, `rgba(${r},${g},${b},${spikeAlpha * 0.2})`);
        grad.addColorStop(0.45, `rgba(${r},${g},${b},${spikeAlpha * 0.5})`);
        grad.addColorStop(0.5, `rgba(${r},${g},${b},${spikeAlpha})`);
        grad.addColorStop(0.55, `rgba(${r},${g},${b},${spikeAlpha * 0.5})`);
        grad.addColorStop(0.65, `rgba(${r},${g},${b},${spikeAlpha * 0.2})`);
        grad.addColorStop(1, `rgba(${r},${g},${b},0)`);

        ctx.strokeStyle = grad;
        ctx.beginPath();
        ctx.moveTo(arm.x1, arm.y1);
        ctx.lineTo(arm.x2, arm.y2);
        ctx.stroke();
      });
    }
  }

  class Starfield {
    constructor() {
      this.canvas = document.getElementById("starfield-canvas");
      if (!this.canvas) return;

      this.ctx = this.canvas.getContext("2d");
      this.stars = [];
      this.mouseX = 0.5; // normalized 0-1
      this.mouseY = 0.5;
      this.smoothMouseX = 0.5;
      this.smoothMouseY = 0.5;

      this.resize();
      this.init();

      window.addEventListener("resize", () => this.resize());
      window.addEventListener("mousemove", (e) => this.onMouseMove(e));

      this.animate();
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;

      // Reposition stars for new dimensions
      this.stars.forEach((star) => {
        star.width = this.canvas.width;
        star.height = this.canvas.height;
        // Reposition if out of bounds
        if (star.x > this.canvas.width)
          star.x = Math.random() * this.canvas.width;
        if (star.y > this.canvas.height)
          star.y = Math.random() * this.canvas.height;
      });
    }

    init() {
      this.stars = [];
      for (let i = 0; i < starCount; i++) {
        this.stars.push(new Star(this.canvas.width, this.canvas.height));
      }
    }

    onMouseMove(e) {
      this.mouseX = e.clientX / window.innerWidth;
      this.mouseY = e.clientY / window.innerHeight;
    }

    animate() {
      // Smooth mouse movement (lerp)
      this.smoothMouseX += (this.mouseX - this.smoothMouseX) * 0.05;
      this.smoothMouseY += (this.mouseY - this.smoothMouseY) * 0.05;

      // Clear canvas
      this.ctx.fillStyle = "#000000";
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      // Sort by depth (far first)
      this.stars.sort((a, b) => a.depth - b.depth);

      // Update and draw
      this.stars.forEach((star) => {
        star.update(
          this.smoothMouseX,
          this.smoothMouseY,
          this.canvas.width,
          this.canvas.height,
        );
        star.draw(this.ctx);
      });

      requestAnimationFrame(() => this.animate());
    }
  }

  new Starfield();
</script>

<style>
  .starfield-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    z-index: -1;
    pointer-events: none;
  }

  #starfield-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: block;
    margin: 0;
    padding: 0;
  }
</style>
