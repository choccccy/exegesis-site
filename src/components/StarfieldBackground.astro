---
/**
 * StarfieldBackground component
 * Renders a sparse, realistic starfield with vertical scroll parallax
 * Zero JS scroll tracking — canvas is absolute at document height, scrolls naturally
 */

interface Props {
  starCount?: number;
}

const { starCount = 800 } = Astro.props;
---

<div class="starfield-wrapper">
  <canvas id="starfield-canvas"></canvas>
</div>

<script define:vars={{ starCount }} client:only>
  class Star {
    constructor(width, height) {
      this.width = width;
      this.height = height;
      this.init();
    }

    init() {
      this.x = Math.random() * this.width;
      this.y = Math.random() * this.height;

      const spectralTypes = [
        { color: "#d0d8ff", brightness: 0.95 },
        { color: "#c8d0ff", brightness: 0.9 },
        { color: "#e0e8ff", brightness: 0.85 },
        { color: "#ffffff", brightness: 0.8 },
        { color: "#f0f0ff", brightness: 0.75 },
        { color: "#e8e8ff", brightness: 0.7 },
        { color: "#fff8f0", brightness: 0.65 },
        { color: "#fff0e0", brightness: 0.6 },
        { color: "#fffff0", brightness: 0.55 },
        { color: "#ffe8b0", brightness: 0.5 },
        { color: "#ffe0a0", brightness: 0.45 },
        { color: "#ffb060", brightness: 0.35 },
        { color: "#ffa040", brightness: 0.3 },
        { color: "#ff6040", brightness: 0.2 },
        { color: "#ff4020", brightness: 0.15 },
        { color: "#ffffff", brightness: 0.25 },
        { color: "#f8f8ff", brightness: 0.2 },
        { color: "#f0f0f8", brightness: 0.15 },
        { color: "#e8e8f0", brightness: 0.1 },
        { color: "#e0e0e8", brightness: 0.08 },
        { color: "#d8d8e0", brightness: 0.05 },
      ];

      const weights = [
        1, 0, 0, 1, 0, 0,
        1, 1, 1, 2, 2,
        3, 3, 1, 1,
        25, 25, 25, 25, 25, 25,
      ];
      const totalWeight = weights.reduce((a, b) => a + b, 0);
      let rand = Math.random() * totalWeight;
      let typeIdx = 0;
      for (let i = 0; i < weights.length; i++) {
        rand -= weights[i];
        if (rand <= 0) { typeIdx = i; break; }
      }

      const spectralType = spectralTypes[typeIdx];
      this.color = spectralType.color;
      this.baseOpacity = spectralType.brightness;
      this.depth = Math.random();
      this.baseSize = 1;
    }

    draw(ctx) {
      const px = Math.round(this.x);
      const py = Math.round(this.y);

      ctx.globalAlpha = this.baseOpacity;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(px, py, 1, 0, Math.PI * 2);
      ctx.fill();

      if (!this.drawSpikes) return;

      const len = this.spikeLength;
      const base = this.spikeRGBA;
      const alphas = this.spikeAlphas;
      const stops = this.spikeStops;
      const arms = [
        { x1: px - len, y1: py - len, x2: px + len, y2: py + len },
        { x1: px + len, y1: py - len, x2: px - len, y2: py + len },
      ];

      ctx.lineWidth = 1;
      arms.forEach((arm) => {
        const grad = ctx.createLinearGradient(arm.x1, arm.y1, arm.x2, arm.y2);
        stops.forEach((stop, i) => {
          grad.addColorStop(stop, `${base}${alphas[i]})`);
        });
        ctx.strokeStyle = grad;
        ctx.beginPath();
        ctx.moveTo(arm.x1, arm.y1);
        ctx.lineTo(arm.x2, arm.y2);
        ctx.stroke();
      });
    }
  }

  class Starfield {
    constructor() {
      this.canvas = document.getElementById("starfield-canvas");
      if (!this.canvas) return;
      this.ctx = this.canvas.getContext("2d");
      this.stars = [];
      this.initialized = false;

      this.initWhenReady();

      window.addEventListener("resize", () => this.resize());
      window.addEventListener("mousemove", (e) => this.onMouseMove(e));
    }

    async initWhenReady() {
      // Wait for document to settle so we can read full height
      await new Promise(r => {
        if (document.readyState === "complete") r();
        else window.addEventListener("load", r);
      });
      // Extra delay for astro islands / lazy content
      await new Promise(r => setTimeout(r, 200));

      this.resize();
      this.initStars();
      this.initialized = true;
      this.animate();

      // Watch for layout changes
      const observer = new ResizeObserver(() => this.resize());
      observer.observe(document.body);
      observer.observe(document.documentElement);
    }

    getDocSize() {
      return {
        w: Math.max(document.body.scrollWidth, document.documentElement.scrollWidth, window.innerWidth),
        h: Math.max(document.body.scrollHeight, document.documentElement.scrollHeight, window.innerHeight),
      };
    }

    resize() {
      const { w, h } = this.getDocSize();
      if (this.canvas.width === w && this.canvas.height === h && this.stars.length) return;

      this.canvas.width = w;
      this.canvas.height = h;

      if (this.stars.length) {
        // Just update star dimensions — don't reposition existing stars
        this.stars.forEach((star) => {
          star.width = w;
          star.height = h;
        });
      }
    }

    initStars() {
      const isLowEnd = navigator.hardwareConcurrency <= 4 || window.innerWidth < 768;
      const count = isLowEnd ? Math.floor(starCount * 0.5) : starCount;

      this.stars = [];
      this.canvas._prevW = this.canvas.width;

      for (let i = 0; i < count; i++) {
        const star = new Star(this.canvas.width, this.canvas.height);
        if (star.baseOpacity >= 0.4) {
          const hex = star.color;
          const r = parseInt(hex.slice(1, 3), 16);
          const g = parseInt(hex.slice(3, 5), 16);
          const b = parseInt(hex.slice(5, 7), 16);
          const spikeAlpha = star.baseOpacity * 0.4;
          const spikeLength = star.baseSize * 32;
          star.spikeRGBA = `rgba(${r},${g},${b},`;
          star.spikeAlphas = [0, spikeAlpha * 0.2, spikeAlpha * 0.5, spikeAlpha, spikeAlpha * 0.5, spikeAlpha * 0.2, 0];
          star.spikeStops = [0, 0.35, 0.45, 0.5, 0.55, 0.65, 1];
          star.spikeLength = spikeLength;
          star.drawSpikes = true;
        } else {
          star.drawSpikes = false;
        }
        this.stars.push(star);
      }
    }

    onMouseMove(e) {
      this.mouseX = e.clientX / window.innerWidth;
      this.mouseY = e.clientY / window.innerHeight;
    }

    animate() {
      if (!this.initialized) return;

      this.ctx.fillStyle = "#000000";
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      this.stars.sort((a, b) => a.depth - b.depth);
      this.stars.forEach((star) => star.draw(this.ctx));

      requestAnimationFrame(() => this.animate());
    }
  }

  new Starfield();
</script>

<style>
  .starfield-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    z-index: -1;
    pointer-events: none;
  }

  #starfield-canvas {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    margin: 0;
    padding: 0;
  }
</style>
