---
/**
 * StarfieldBackground component
 * Renders a sparse, realistic starfield with subtle mouse parallax
 * Hard sci-fi aesthetic: static stars, minimal movement
 */

interface Props {
  starCount?: number;
}

const { starCount = 800 } = Astro.props;
---

<div class="starfield-wrapper">
  <canvas id="starfield-canvas"></canvas>
</div>

<script define:vars={{ starCount }} client:only>
  class Star {
    constructor(width, height) {
      this.width = width;
      this.height = height;
      this.init();
    }

    init() {
      // Position
      this.x = Math.random() * this.width;
      this.y = Math.random() * this.height;

      // Spectral class determines both color and intrinsic brightness
      // Naked-eye sky: most visible stars are distant white A/F types
      // Warm colors are rare giants/supergiants among the brighter stars
      const spectralTypes = [
        // O/B - blue-white, very bright, extremely rare
        { color: "#d0d8ff", brightness: 0.95 },
        { color: "#c8d0ff", brightness: 0.9 },
        { color: "#e0e8ff", brightness: 0.85 },
        // A - white, bright, rare
        { color: "#ffffff", brightness: 0.8 },
        { color: "#f0f0ff", brightness: 0.75 },
        { color: "#e8e8ff", brightness: 0.7 },
        // F - yellow-white, moderate-bright
        { color: "#fff8f0", brightness: 0.65 },
        { color: "#fff0e0", brightness: 0.6 },
        { color: "#fffff0", brightness: 0.55 },
        // G - yellow, moderate
        { color: "#ffe8b0", brightness: 0.5 },
        { color: "#ffe0a0", brightness: 0.45 },
        // K giants - orange, dim-moderate (rare)
        { color: "#ffb060", brightness: 0.35 },
        { color: "#ffa040", brightness: 0.3 },
        // M supergiants - red, dim (very rare)
        { color: "#ff6040", brightness: 0.2 },
        { color: "#ff4020", brightness: 0.15 },
        // Dim background stars: grey-white (distant A/F/G types)
        { color: "#ffffff", brightness: 0.25 },
        { color: "#f8f8ff", brightness: 0.2 },
        { color: "#f0f0f8", brightness: 0.15 },
        { color: "#e8e8f0", brightness: 0.1 },
        { color: "#e0e0e8", brightness: 0.08 },
        { color: "#d8d8e0", brightness: 0.05 },
      ];

      // Weighted: ~88% dim grey-white, ~12% visible stars
      // Bright stars (O/B, A @ 0.8+) reduced to ~10 per 800-star field
      const weights = [
        1, 0, 0, // O/B: blue-white (only the brightest, very rare)
        1, 0, 0, // A: white (only the 0.8 variant)
        1, 1, 1, // F: yellow-white
        2, 2,    // G: yellow
        3, 3,    // K: orange
        1, 1,    // M: red
        25, 25, 25, 25, 25, 25, // Dim white/grey background
      ];
      const totalWeight = weights.reduce((a, b) => a + b, 0);
      let rand = Math.random() * totalWeight;
      let typeIdx = 0;
      for (let i = 0; i < weights.length; i++) {
        rand -= weights[i];
        if (rand <= 0) {
          typeIdx = i;
          break;
        }
      }

      const spectralType = spectralTypes[typeIdx];
      this.color = spectralType.color;
      this.baseOpacity = spectralType.brightness;

      // Depth: continuous 0-1 for unique parallax per star
      this.depth = Math.random();
      this.baseSize = 1;
    }

    update(canvasWidth, canvasHeight) {
      const scrollOffset = window.scrollY;

      // Vertical parallax: each star has its own speed (0.95x to 0.6x based on depth)
      const parallaxRatio = 0.6 + this.depth * 0.35;
      const parallaxY = scrollOffset * parallaxRatio;

      this.drawX = this.x;
      this.drawY = this.y - parallaxY;

      // Seamless tiling via modulo — works at any scroll depth
      const margin = 10;
      const wrapW = canvasWidth + margin * 2;
      const wrapH = canvasHeight + margin * 2;
      this.drawX = ((this.drawX % wrapW) + wrapW) % wrapW - margin;
      this.drawY = ((this.drawY % wrapH) + wrapH) % wrapH - margin;
    }

    draw(ctx) {
      // Round to whole pixels to prevent anti-aliasing blur
      const px = Math.round(this.drawX);
      const py = Math.round(this.drawY);

      // All stars are single pixel, brightness varies
      ctx.globalAlpha = this.baseOpacity;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(px, py, 1, 0, Math.PI * 2);
      ctx.fill();

      // Diffraction spikes on all stars (scaled by brightness, prominent)
      const spikeAlpha = this.baseOpacity * 0.4;
      ctx.lineWidth = 1;
      const spikeLength = this.baseSize * 32;

      // Parse color for gradient - handle hex colors
      const hex = this.color;
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);

      // Draw 4 diagonal arms with wide, gradual tapering
      const arms = [
        { x1: px - spikeLength, y1: py - spikeLength, x2: px + spikeLength, y2: py + spikeLength },
        { x1: px + spikeLength, y1: py - spikeLength, x2: px - spikeLength, y2: py + spikeLength },
      ];

      arms.forEach((arm) => {
        const grad = ctx.createLinearGradient(arm.x1, arm.y1, arm.x2, arm.y2);
        grad.addColorStop(0, `rgba(${r},${g},${b},0)`);
        grad.addColorStop(0.35, `rgba(${r},${g},${b},${spikeAlpha * 0.2})`);
        grad.addColorStop(0.45, `rgba(${r},${g},${b},${spikeAlpha * 0.5})`);
        grad.addColorStop(0.5, `rgba(${r},${g},${b},${spikeAlpha})`);
        grad.addColorStop(0.55, `rgba(${r},${g},${b},${spikeAlpha * 0.5})`);
        grad.addColorStop(0.65, `rgba(${r},${g},${b},${spikeAlpha * 0.2})`);
        grad.addColorStop(1, `rgba(${r},${g},${b},0)`);

        ctx.strokeStyle = grad;
        ctx.beginPath();
        ctx.moveTo(arm.x1, arm.y1);
        ctx.lineTo(arm.x2, arm.y2);
        ctx.stroke();
      });
    }
  }

  class Starfield {
    constructor() {
      this.canvas = document.getElementById("starfield-canvas");
      if (!this.canvas) return;

      this.ctx = this.canvas.getContext("2d");
      this.ctx.imageSmoothingEnabled = false;
      this.stars = [];

      this.resize();
      this.init();

      window.addEventListener("resize", () => this.resize());

      this.animate();
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;

      this.stars.forEach((star) => {
        star.width = this.canvas.width;
        star.height = this.canvas.height;
        if (star.x > this.canvas.width)
          star.x = Math.random() * this.canvas.width;
        if (star.y > this.canvas.height)
          star.y = Math.random() * this.canvas.height;
      });
    }

    init() {
      this.stars = [];
      for (let i = 0; i < starCount; i++) {
        this.stars.push(new Star(this.canvas.width, this.canvas.height));
      }
    }

    animate() {
      this.ctx.fillStyle = "#000000";
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      this.stars.sort((a, b) => a.depth - b.depth);

      this.stars.forEach((star) => {
        star.update(
          this.canvas.width,
          this.canvas.height,
        );
        star.draw(this.ctx);
      });

      requestAnimationFrame(() => this.animate());
    }
  }

  new Starfield();
</script>

<style>
  .starfield-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    z-index: -1;
    pointer-events: none;
    isolation: isolate;
  }

  #starfield-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: block;
    margin: 0;
    padding: 0;
    will-change: transform;
    contain: strict;
  }
</style>
