---
/**
 * StarfieldBackground component
 * Renders a sparse, realistic starfield with hardware-accelerated CSS parallax
 * Uses pre-rendered seamless textures to achieve 60fps performance without motion blur
 */

interface Props {
  starCount?: number;
}

const { starCount = 800 } = Astro.props;
---

<div id="starfield-wrapper">
  <div class="starfield-layer" id="starfield-bg"></div>
  <div class="starfield-layer" id="starfield-md"></div>
  <div class="starfield-layer" id="starfield-fg"></div>
</div>

<script define:vars={{ starCount }} client:only>
  class Star {
    constructor(width, height) {
      this.width = width;
      this.height = height;
      this.init();
    }

    init() {
      this.x = Math.random() * this.width;
      this.y = Math.random() * this.height;

      const spectralTypes = [
        { color: "#d0d8ff", brightness: 0.95 },
        { color: "#c8d0ff", brightness: 0.9 },
        { color: "#e0e8ff", brightness: 0.85 },
        { color: "#ffffff", brightness: 0.8 },
        { color: "#f0f0ff", brightness: 0.75 },
        { color: "#e8e8ff", brightness: 0.7 },
        { color: "#fff8f0", brightness: 0.65 },
        { color: "#fff0e0", brightness: 0.6 },
        { color: "#fffff0", brightness: 0.55 },
        { color: "#ffe8b0", brightness: 0.5 },
        { color: "#ffe0a0", brightness: 0.45 },
        { color: "#ffb060", brightness: 0.35 },
        { color: "#ffa040", brightness: 0.3 },
        { color: "#ff6040", brightness: 0.2 },
        { color: "#ff4020", brightness: 0.15 },
        { color: "#ffffff", brightness: 0.25 },
        { color: "#f8f8ff", brightness: 0.2 },
        { color: "#f0f0f8", brightness: 0.15 },
        { color: "#e8e8f0", brightness: 0.1 },
        { color: "#e0e0e8", brightness: 0.08 },
        { color: "#d8d8e0", brightness: 0.05 },
      ];

      const weights = [
        1, 0, 0, 1, 0, 0,
        1, 1, 1, 2, 2,
        3, 3, 1, 1,
        25, 25, 25, 25, 25, 25,
      ];
      const totalWeight = weights.reduce((a, b) => a + b, 0);
      let rand = Math.random() * totalWeight;
      let typeIdx = 0;
      for (let i = 0; i < weights.length; i++) {
        rand -= weights[i];
        if (rand <= 0) { typeIdx = i; break; }
      }

      const spectralType = spectralTypes[typeIdx];
      this.color = spectralType.color;
      this.baseOpacity = spectralType.brightness;
      this.depth = Math.random();
      this.baseSize = 1;
      
      const SPIKE_ALPHA_MULTIPLIER = 0.48;
      const SPIKE_LENGTH_MULTIPLIER = 32;

      const hex = this.color;
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      
      const spikeAlpha = this.baseOpacity * SPIKE_ALPHA_MULTIPLIER;
      this.spikeRGBA = `rgba(${r},${g},${b},`;
      this.spikeAlphas = [0, spikeAlpha * 0.2, spikeAlpha * 0.5, spikeAlpha, spikeAlpha * 0.5, spikeAlpha * 0.2, 0];
      this.spikeStops = [0, 0.35, 0.45, 0.5, 0.55, 0.65, 1];
      this.spikeLength = this.baseSize * SPIKE_LENGTH_MULTIPLIER;
      this.drawSpikes = true; // All stars get spikes to ensure colors are visible
    }

    draw(ctx, renderX, renderY) {
      const px = Math.round(renderX);
      const py = Math.round(renderY);

      ctx.globalAlpha = this.baseOpacity;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(px, py, 1, 0, Math.PI * 2);
      ctx.fill();

      if (!this.drawSpikes) return;

      const len = this.spikeLength;
      const base = this.spikeRGBA;
      const alphas = this.spikeAlphas;
      const stops = this.spikeStops;
      const arms = [
        { x1: px - len, y1: py - len, x2: px + len, y2: py + len },
        { x1: px + len, y1: py - len, x2: px - len, y2: py + len },
      ];

      ctx.lineWidth = 1;
      arms.forEach((arm) => {
        const grad = ctx.createLinearGradient(arm.x1, arm.y1, arm.x2, arm.y2);
        stops.forEach((stop, i) => {
          grad.addColorStop(stop, `${base}${alphas[i]})`);
        });
        ctx.strokeStyle = grad;
        ctx.beginPath();
        ctx.moveTo(arm.x1, arm.y1);
        ctx.lineTo(arm.x2, arm.y2);
        ctx.stroke();
      });
    }

    // Draws the star on the canvas, handling wrapping for seamless tiling
    drawSeamless(ctx, texSize) {
      const margin = this.drawSpikes ? this.spikeLength : 2;
      
      // Draw primary instance
      this.draw(ctx, this.x, this.y);

      // Check edges and draw mirrored copies to ensure perfect seamless wrapping
      const nearLeft = this.x < margin;
      const nearRight = this.x > texSize - margin;
      const nearTop = this.y < margin;
      const nearBottom = this.y > texSize - margin;

      if (nearLeft) this.draw(ctx, this.x + texSize, this.y);
      if (nearRight) this.draw(ctx, this.x - texSize, this.y);
      if (nearTop) this.draw(ctx, this.x, this.y + texSize);
      if (nearBottom) this.draw(ctx, this.x, this.y - texSize);

      // Corners
      if (nearLeft && nearTop) this.draw(ctx, this.x + texSize, this.y + texSize);
      if (nearRight && nearTop) this.draw(ctx, this.x - texSize, this.y + texSize);
      if (nearLeft && nearBottom) this.draw(ctx, this.x + texSize, this.y - texSize);
      if (nearRight && nearBottom) this.draw(ctx, this.x - texSize, this.y - texSize);
    }
  }

  class CSSStarfield {
    constructor() {
      this.wrapper = document.getElementById("starfield-wrapper");
      if (!this.wrapper) return;
      
      this.texSize = 1024; // Use 1024x1024 seamless tiles for high performance
      this.init();
    }

    init() {
      // Base density: 800 stars per 1024x1024 tile is extremely dense compared to 
      // the original document-wide distribution, but provides the richest sky feel.
      const isLowEnd = navigator.hardwareConcurrency <= 4 || window.innerWidth < 768;
      // We'll multiply starCount by 1.5 to guarantee a huge number of stars since 90% are dim
      let count = isLowEnd ? Math.floor(starCount * 0.5) : Math.floor(starCount * 1.5);
      
      // Partition stars into 3 depth layers for parallax
      const layers = [
        { id: 'starfield-bg', stars: [] },
        { id: 'starfield-md', stars: [] },
        { id: 'starfield-fg', stars: [] }
      ];

      for (let i = 0; i < count; i++) {
        const star = new Star(this.texSize, this.texSize);
        // Distribute to layers based on depth
        if (star.depth < 0.33) layers[0].stars.push(star);
        else if (star.depth < 0.66) layers[1].stars.push(star);
        else layers[2].stars.push(star);
      }

      // Render each layer to a data URL
      const canvas = document.createElement("canvas");
      canvas.width = this.texSize;
      canvas.height = this.texSize;
      const ctx = canvas.getContext("2d");

      for (const layer of layers) {
        // Reset globalAlpha to 1.0 so we actually clear the canvas with opaque black,
        // otherwise the last drawn star's alpha leaks into the fillRect and causes ghosting!
        ctx.globalAlpha = 1.0;
        ctx.fillStyle = "#000000";
        ctx.fillRect(0, 0, this.texSize, this.texSize);
        
        layer.stars.forEach(star => star.drawSeamless(ctx, this.texSize));
        
        const dataUrl = canvas.toDataURL("image/png");
        const el = document.getElementById(layer.id);
        if (el) {
          el.style.backgroundImage = `url(${dataUrl})`;
        }
      }

      // Cleanup
      canvas.width = 0;
      canvas.height = 0;

      // Start listeners
      this.setupListeners();
    }

    setupListeners() {
      let scrollY = window.scrollY;
      let ticking = false;

      const updateCSSVars = () => {
        // We use CSS custom properties to pass values to the highly-optimized compositor
        this.wrapper.style.setProperty('--scroll-y', `${scrollY}px`);
        ticking = false;
      };

      const requestUpdate = () => {
        if (!ticking) {
          requestAnimationFrame(updateCSSVars);
          ticking = true;
        }
      };

      window.addEventListener('scroll', () => {
        scrollY = window.scrollY;
        requestUpdate();
      }, { passive: true });

      // Initial update
      requestUpdate();
    }
  }

  // We delay init slightly to ensure UI is interactive first without blocking main thread
  setTimeout(() => new CSSStarfield(), 50);
</script>

<style>
  #starfield-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
    background-color: #000000;
  }

  .starfield-layer {
    position: absolute;
    top: -50px;
    left: -50px;
    right: -50px;
    bottom: -50px;
    background-repeat: repeat;
    /* Hardware acceleration hint */
    will-change: background-position;
    /* Screen blend mode ensures the black background becomes transparent, 
       perfectly preserving the pre-blended RGB canvas colors */
    mix-blend-mode: screen;
  }

  /* Different speeds for parallax. 
     We subtract --scroll-y so the background moves UP as you scroll DOWN,
     mimicking things moving past you natively. */
  #starfield-bg {
    /* 10% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.1);
  }

  #starfield-md {
    /* 30% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.3);
  }

  #starfield-fg {
    /* 60% speed */
    background-position: 0px calc(var(--scroll-y, 0px) * -0.6);
  }
</style>
